//@version=6
indicator("Volume Zone Oscillator with Floating Levels", shorttitle="VZO FL", precision=2)

// --- Inputs ---
inp_period      = input.int(14, "Period", minval=1)
inp_fl_lookback = input.int(12, "Floating Levels Lookback", minval=1)
inp_fl_up_pct   = input.float(50.0, "Floating Levels Up (%)", minval=0, maxval=100)
inp_fl_dn_pct   = input.float(50.0, "Floating Levels Down (%)", minval=0, maxval=100)

// --- VZO Logic ---
// Calculate sign of close movement
float sign = close > close[1] ? 1.0 : (close < close[1] ? -1.0 : 0.0)
float r_val = sign * volume

// MQL5 uses alpha = 2.0 / (1.0 + period), which is the standard EMA definition
float vp = ta.ema(r_val, inp_period)
float tv = ta.ema(volume, inp_period)

// Calculate VZO Ratio
float vzo = tv != 0 ? 100.0 * vp / tv : 0.0

// --- Floating Levels Logic ---
float fl_min = ta.lowest(vzo, inp_fl_lookback)
float fl_max = ta.highest(vzo, inp_fl_lookback)
float range_val = fl_max - fl_min

float lev_up = fl_min + (inp_fl_up_pct * range_val / 100.0)
float lev_dn = fl_min + (inp_fl_dn_pct * range_val / 100.0)

// --- Trend and Coloring ---
// Colors using hex codes for stability in version 6
color color_bull = #00ff00 // Green
color color_bear = #ff0000 // Red
color color_neut = #808080 // Gray
color color_fill = #dcdcdc // Gainsboro-like

color vzo_color = vzo > lev_up ? color_bull : (vzo < lev_dn ? color_bear : color_neut)

// --- Plots ---
// Explicit parameter names to satisfy Pine Script v6 compiler requirements
plot(series=vzo, title="VZO", color=vzo_color, linewidth=2)
plot_up = plot(series=lev_up, title="Level Up", color=color.new(#d3d3d3, 50))
plot_dn = plot(series=lev_dn, title="Level Down", color=color.new(#d3d3d3, 50))

// Zone filling matching DRAW_FILLING in MQL5
fill(plot1=plot_up, plot2=plot_dn, color=color.new(color_fill, 80), title="Filling")

// Zero line for reference
hline(price=0, title="Zero Line", color=color.new(#808080, 70), linestyle=hline.style_dotted)
