input bool     inpUseAutoLot = false;       // Usar cálculo automático de lotes?
input double   inpRiskPercent = 2.0;        // Risco por operação (%)
input double   inpMaxLotSize = 1.0;         // Lote máximo permitido

// Parâmetros de Stop Loss e Take Profit
input group "=== Stop Loss & Take Profit ==="
input int      inpStopLossPoints = 300;     // Stop Loss fixo em pontos
input int      inpTakeProfitPoints = 600;   // Take Profit fixo em pontos

// Parâmetros de Trailing Stop
input group "=== Trailing Stop ==="
input bool     inpUseTrailingStop = true;   // Ativar Trailing Stop
input int      inpTrailingStart = 100;      // Iniciar trailing quando lucro atingir
input int      inpTrailingStep = 50;        // Avançar trailing a cada
input int      inpTrailingDistance = 50;    // Distância do trailing stop

// Parâmetros do Sistema
input group "=== Trading System ==="
input int      inpMagicNumber = 12345;      // Magic Number
input int      inpSlippage = 30;            // Slippage permitido
input int      inpCooldownMinutes = 60;     // Cooldown entre sinais

// Parâmetros ATR Trend Envelope
input group "=== ATR Trend Envelope Settings ==="
input int     inpAtrPeriod = 14;            // ATR period
input double  inpDeviation = 1.5;           // ATR multiplication factor

// Parâmetros VZO
input group "=== Volume Zone Oscillator Settings ==="
input int     inpVzoPeriod = 14;            // VZO Period
input int     inpFlLookBack = 12;           // Floating levels look back
input double  inpFlLevelUp = 50.0;          // Upper level %
input double  inpFlLevelDown = 50.0;        // Lower level %

// Parâmetros WaveWeis
input group "=== WaveWeis Settings ==="
input int     inpWaveIntensity = 50;        // Intensity window

// Parâmetros Bollinger Bands
input group "=== Bollinger Bands Settings ==="
input int     inpBbPeriod = 20;             // Bollinger period
input double  inpBbDeviation = 2.0;         // Bollinger deviation

